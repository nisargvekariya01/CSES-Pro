{
  "manifest_version": 3,
  "name": "CSES Pro",
  "version": "1.0.0",
  "description": "Enhance your CSES experience with progress tracking, Codeforces-style features, advanced sorting, and more.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/username.ts-loader-DcoepsbT.js",
        "assets/solvedProblems.ts-loader-D7xQ3I7j.js",
        "assets/bookmarks.ts-loader-BhPdlJMs.js",
        "assets/injectDashboard.ts-loader-C0Wd2uoe.js",
        "assets/submitEditor.ts-loader-CXskSyVu.js",
        "assets/copyBlocks.ts-loader-BIzRgpNP.js"
      ],
      "matches": [
        "*://cses.fi/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://cses.fi/*"
  ],
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "*://cses.fi/*"
      ],
      "resources": [
        "assets/parser-CDGgk22_.js",
        "assets/storage-39e_FlVG.js",
        "assets/username.ts-DFdXV1va.js",
        "assets/solvedProblems.ts-ChlWXIf8.js",
        "assets/bookmarks.ts-CfmkRqez.js",
        "assets/cses-problems-BDV4gcZH.js",
        "assets/injectDashboard.ts-DDeMvplE.js",
        "assets/submitEditor.ts-CBqGn-C8.js",
        "assets/copyBlocks.ts-CD-FJEwo.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
