{
  "manifest_version": 3,
  "name": "CSES Pro",
  "version": "1.0.0",
  "description": "Enhance your CSES experience with progress tracking, Codeforces-style features, advanced sorting, and more.",
  "action": {
    "default_icon": {
      "16": "icons/image.png",
      "48": "icons/image.png",
      "128": "icons/image.png"
    }
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/username.ts-loader-C07u2fRt.js",
        "assets/solvedProblems.ts-loader-BiVv9Eo6.js",
        "assets/bookmarks.ts-loader-CAnaWi9E.js",
        "assets/injectDashboard.ts-loader-CZDV5B7g.js",
        "assets/submitEditor.ts-loader-CXskSyVu.js",
        "assets/copyBlocks.ts-loader-EnDG_kB7.js"
      ],
      "matches": [
        "*://cses.fi/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://cses.fi/*"
  ],
  "icons": {
    "16": "icons/image.png",
    "48": "icons/image.png",
    "128": "icons/image.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "*://cses.fi/*"
      ],
      "resources": [
        "assets/parser-CDGgk22_.js",
        "assets/storage-3fLFYjv2.js",
        "assets/username.ts-C0N937tn.js",
        "assets/solvedProblems.ts-v5ydPmCB.js",
        "assets/bookmarks.ts-FV8YT_Pw.js",
        "assets/injectDashboard.ts-Duzc1jEG.js",
        "assets/submitEditor.ts-CBqGn-C8.js",
        "assets/copyBlocks.ts-t29McPee.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
