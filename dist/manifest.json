{
  "manifest_version": 3,
  "name": "CSES Pro",
  "version": "1.0.0",
  "description": "Enhance your CSES experience with progress tracking, Codeforces-style features, advanced sorting, and more.",
  "action": {
    "default_icon": {
      "16": "icons/image.png",
      "48": "icons/image.png",
      "128": "icons/image.png"
    }
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/username.ts-loader-o_mMMZ27.js",
        "assets/solvedProblems.ts-loader-D-aRVG5K.js",
        "assets/bookmarks.ts-loader-CBWQbQAw.js",
        "assets/injectDashboard.ts-loader-B4VQbZnH.js",
        "assets/submitEditor.ts-loader-DWOfGEbY.js",
        "assets/copyBlocks.ts-loader-BCFAd2yV.js"
      ],
      "matches": [
        "*://cses.fi/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://cses.fi/*"
  ],
  "icons": {
    "16": "icons/image.png",
    "48": "icons/image.png",
    "128": "icons/image.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "*://cses.fi/*"
      ],
      "resources": [
        "assets/parser-CT_qkLUG.js",
        "assets/storage-DPB6uFbM.js",
        "assets/username.ts-CAKMZgjK.js",
        "assets/cses-problems-BDV4gcZH.js",
        "assets/solvedProblems.ts-Ca4289xt.js",
        "assets/bookmarks.ts-DA8sksko.js",
        "assets/injectDashboard.ts-CuVVWfSk.js",
        "assets/submitEditor.ts-_KJxN2VK.js",
        "assets/copyBlocks.ts-BTSQvWBm.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
